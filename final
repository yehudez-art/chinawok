            System.out.println("4. Los más vendidos");
            System.out.println("5. Datos del cliente");
            System.out.println("6. Cerrar Sesión / Volver");

            System.out.print("Seleccione una opción: ");
            opcion = sc.nextInt();
            sc.nextLine();

            switch (opcion) {
                case 1:
                    combosPersonales(sc);
                    break;
                case 2:
                    paraCompartir(sc);
                    break;
                case 3:
                    promosFamiliares(sc);
                    break;
                case 4:
                    masVendidos(sc);
                    break;
                case 5:
                    datosCliente(sc);
                    break;
                case 6:
                    System.out.println("Regresando al menú de inicio...");
                    break;
                default:
                    System.out.println("Opción inválida");
            }
        } while (opcion != 6);
    }

