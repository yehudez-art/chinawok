    public static void mostrarProductos(Scanner sc, String[] productos, double[] precios) {
        int opcion;
        int cantidad;
        double total;

        System.out.println("===== PRODUCTOS =====");
        for (int i = 0; i < productos.length; i++) {
            System.out.println((i + 1) + ". " + productos[i] + " - S/ " + precios[i]);
        }

        System.out.print("Seleccione un producto: ");
        opcion = sc.nextInt();
        sc.nextLine();

        if (opcion >= 1 && opcion <= productos.length) {
            System.out.print("Ingrese cantidad: ");
            cantidad = sc.nextInt();
            sc.nextLine();

            total = precios[opcion - 1] * cantidad;
            String productoSeleccionado = productos[opcion - 1];
            double precioUnidad = precios[opcion - 1];

            int metodoPago;
            String metodoStr = "";
            boolean pagoValido = false;

            do {
                System.out.println("--- SELECCIONE MÉTODO DE PAGO ---");
                System.out.println("1. Efectivo (Pago en caja)");
                System.out.println("2. Tarjeta de Crédito / Débito");
                System.out.println("3. Yape / Plin (Billetera Digital)");
                System.out.print("Seleccione una opción: ");
                metodoPago = sc.nextInt();
                sc.nextLine();

                switch (metodoPago) {
                    case 1:
                        metodoStr = "Efectivo";
                        pagoValido = true;
                        break;
                    case 2:
                        metodoStr = "Tarjeta";
                        pagoValido = true;
                        break;
                    case 3:
                        metodoStr = "Yape/Plin";
                        pagoValido = true;
                        break;
                    default:
                        System.out.println("Opción no válida.");
                        break;
                }
            } while (!pagoValido);

            System.out.println("====================================");
            System.out.println("     BOLETA DE VENTA - CHINAWOK     ");
            System.out.println("====================================");
            System.out.println("Producto: " + productoSeleccionado);
            System.out.println("Cantidad: " + cantidad);
            System.out.println("Precio Unitario: S/ " + precioUnidad);
            System.out.println("------------------------------------");
            System.out.println("TOTAL A PAGAR: S/ " + total);
            System.out.println("Método de pago: " + metodoStr);
            System.out.println("Fecha de emisión: 29/05/2026");
            System.out.println("====================================");
            System.out.println("¡Gracias por su compra en ChinaWok!");
            System.out.println("====================================");

        } else {
            System.out.println("Producto inválido");
        }
    }

